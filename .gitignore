# --- Python / Test caches ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Experiment outputs ---
logs/
*.log
*.tmp
.tmp_tests/
archive/process_*/

# --- Assets: keep game-domain assets, ignore other latest pointers ---
assets/**/latest_*.json
!assets/game_assets/
!assets/game_assets/*.json

# --- Results: keep only the paper-facing final tables/analysis/figures ---
results/*
!results/tables/
!results/tables/*.csv
!results/tables/*.md
!results/tables/*.tex
!results/analysis/
!results/analysis/*.csv
!results/analysis/*.md
!results/figures/
!results/figures/*.svg

# --- Secrets and env ---
configs/.deepseek_api_key
configs/*.key
.env
.env.*

# --- Third-party downloaded datasets (redistribution-free re-download) ---
data/public/

# --- OS/editor cruft ---
.DS_Store
Thumbs.db
